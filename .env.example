# Server
PORT=4000
CLIENT_ORIGIN=*

# Database (PostgreSQL) — Render "Internal Database URL"-ро гузоред
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Дар локал бе SSL кор кардан хоҳед: DB_NO_SSL=1

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=15
# Voice message max length in seconds (enforced client-side; informational for API)
VOICE_MAX_SECONDS=60
